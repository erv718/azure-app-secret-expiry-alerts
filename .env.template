# ============================================================
# Azure App Secret & Certificate Expiry Alerts - Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.template .env
#
# Lines starting with # are comments. Remove the # to enable a setting.

# ---------------------------
# Azure Authentication
# ---------------------------
# Choose ONE authentication method:
#   "service_principal" - Use client ID/secret (for running outside Azure)
#   "managed_identity"  - Use Azure Managed Identity (for running inside Azure)
AZURE_AUTH_METHOD=service_principal

# Service Principal credentials (required if AZURE_AUTH_METHOD=service_principal)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ---------------------------
# App Filtering (optional)
# ---------------------------
# By default ALL app registrations in the tenant are monitored.
# Use these filters to scope it down. Leave blank to monitor everything.

# Comma-separated list of App IDs (client IDs) to monitor. If set, ONLY these apps are checked.
# FILTER_INCLUDE_APP_IDS=

# Comma-separated app name patterns (case-insensitive substring match).
# If set, ONLY apps whose display name contains one of these patterns are checked.
# FILTER_INCLUDE_NAMES=

# Comma-separated list of App IDs to EXCLUDE from monitoring.
# FILTER_EXCLUDE_APP_IDS=

# Comma-separated app name patterns to EXCLUDE (case-insensitive substring match).
# FILTER_EXCLUDE_NAMES=

# ---------------------------
# Alert Thresholds
# ---------------------------
# Comma-separated list of days before expiry to trigger alerts.
# An alert fires when a secret/certificate expires within this many days.
ALERT_THRESHOLD_DAYS=90,60,30,14,7

# ---------------------------
# Slack Notifications (optional)
# ---------------------------
# Set SLACK_ENABLED=true and provide your webhook URL to receive Slack alerts.
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=

# ---------------------------
# Email Notifications (optional)
# ---------------------------
# Set EMAIL_ENABLED=true and fill in SMTP details to receive email alerts.
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=
# Comma-separated list of recipient email addresses
EMAIL_TO=
